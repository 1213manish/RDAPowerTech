{
  "version": 2,
  "buildCommand": "composer install --no-dev --optimize-autoloader && npm run build",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(assets|css|js|images|fonts|favicon\\.ico|robots\\.txt)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/api/test.php",
      "dest": "/api/test.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "APP_KEY": "base64:6WQgulhHo9vDNSZ42IPkFW51iY8ZlYSGbboZzIDBiu4=",
    "LOG_CHANNEL": "stderr",
    "CACHE_STORE": "array",
    "SESSION_DRIVER": "cookie"
  }
}
